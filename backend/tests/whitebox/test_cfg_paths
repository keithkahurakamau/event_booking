import unittest
import psycopg2
import sys
import os
import uuid

# RESOLUTION PROTOCOL: Namespace path modification to locate the System Under Test (SUT).
sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '../..')))
from booking_transaction import execute_booking

class TestBookingWhiteBoxCFG(unittest.TestCase):
    """
    MATHEMATICAL PROOF OF STRUCTURAL COVERAGE:
    This suite utilizes McCabe's Cyclomatic Complexity to mathematically guarantee 
    100% branch coverage of the core transaction logic.
    
    COMPLEXITY DERIVATION:
    The SUT (execute_booking) contains exactly 4 Predicate Nodes (Decision Points):
      1. Node A: `if not result:` (Entity exists?)
      2. Node B: `if requested_tickets > current_capacity:` (Capacity sufficient?)
      3. Node C: `except IntegrityError:` (Database constraint violation?)
      4. Node D: `except Exception:` (Hardware/Network failure?)
    
    Formula: V(G) = P + 1 
    Calculation: V(G) = 4 + 1 = 5
    Result: Exactly 5 independent execution paths must be tested.
    """

    def setUp(self):
        # STATE INITIALIZATION: Connect to the isolated testing namespace.
        self.conn = psycopg2.connect(
            dbname="event_booking", 
            user="postgres", 
            password="limo91we",
            host="localhost",
            port="5432"
        )
        
        # VECTOR INJECTION: Seed specific test scenarios to force the SUT down 
        # distinct operational branches.
        with self.conn.cursor() as cursor:
            # Vector 1: Standard Event (Used to test Path 1, 2, 4, 5)
            self.valid_event_id = str(uuid.uuid4())
            cursor.execute(
                "INSERT INTO events (event_id, title, total_capacity, available_capacity) VALUES (%s, %s, %s, %s)",
                (self.valid_event_id, 'Path 1 Test Event', 50, 50)
            )
            
            # Vector 2: Constrained Event (Specifically engineered to test Path 3)
            self.low_cap_event_id = str(uuid.uuid4())
            cursor.execute(
                "INSERT INTO events (event_id, title, total_capacity, available_capacity) VALUES (%s, %s, %s, %s)",
                (self.low_cap_event_id, 'Path 3 Test Event', 5, 2) # Only 2 tickets available
            )
        self.conn.commit()

    def tearDown(self):
        # STATE ISOLATION: Rollback any mutated data to ensure test atomicity.
        self.conn.rollback()
        self.conn.close()

    # ==========================================================================
    # PATH 1: NOMINAL EXECUTION (The "Happy Path")
    # ==========================================================================
    def test_path_1_nominal_execution(self):
        """
        CFG PATH 1: Bypasses all Predicate Nodes.
        JUSTIFICATION: Proves the system functions under optimal conditions.
        The entity exists, capacity is sufficient, and no database errors occur.
        Expected State: Successful transaction commit -> 'CONFIRMED'.
        """
        result = execute_booking(self.valid_event_id, 2, self.conn)
        self.assertEqual(result['status'], 'CONFIRMED')

    # ==========================================================================
    # PATH 2: PREDICATE NODE 1 FAULT (Entity Validation)
    # ==========================================================================
    def test_path_2_entity_fault(self):
        """
        CFG PATH 2: Triggers failure at Node A (`if not result:`).
        JUSTIFICATION: Verifies the system's ability to halt execution and reject
        transactions directed at non-existent database entities.
        Expected State: Raises ValueError ('does not exist').
        """
        fake_id = str(uuid.uuid4())
        with self.assertRaisesRegex(ValueError, "does not exist"):
            execute_booking(fake_id, 2, self.conn)

    # ==========================================================================
    # PATH 3: PREDICATE NODE 2 FAULT (Capacity Validation)
    # ==========================================================================
    def test_path_3_capacity_fault(self):
        """
        CFG PATH 3: Passes Node A, but triggers failure at Node B.
        JUSTIFICATION: Proves application-level mitigation against overbooking.
        Requests 5 tickets from an event seeded with only 2 available in `setUp`.
        Expected State: Raises ValueError ('exceeds limit').
        """
        with self.assertRaisesRegex(ValueError, "exceeds limit"):
            execute_booking(self.low_cap_event_id, 5, self.conn) 

    # ==========================================================================
    # PATH 4: PREDICATE NODE 3 FAULT (Database Integrity Violation)
    # ==========================================================================
    def test_path_4_integrity_fault(self):
        """
        CFG PATH 4: Passes Nodes A & B, but fails at execution via Node C interception.
        JUSTIFICATION: Demonstrates the interaction between White Box paths and Black Box 
        boundaries. Submits an invalid partition (x=15). The database throws an IntegrityError,
        which the Python layer must safely catch and route.
        Expected State: Intercepts IntegrityError, executes rollback, raises ValueError.
        """
        with self.assertRaisesRegex(ValueError, "outside the"):
            execute_booking(self.valid_event_id, 15, self.conn) 

    # ==========================================================================
    # PATH 5: PREDICATE NODE 4 FAULT (System/Hardware Exception)
    # ==========================================================================
    def test_path_5_system_fault(self):
        """
        CFG PATH 5: General failure interception at Node D (`except Exception:`).
        JUSTIFICATION: Verifies the system's absolute fault tolerance. If an unexpected
        hardware, network, or object-type error occurs during the transaction, the 
        system must catch it and execute a hard rollback to prevent data corruption.
        Expected State: Intercepts Exception (forced by passing conn=None), propagates it.
        """
        with self.assertRaises(Exception):
            execute_booking(self.valid_event_id, 2, conn=None)

if __name__ == '__main__':
    unittest.main()